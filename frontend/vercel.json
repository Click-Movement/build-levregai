{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "node scripts/vercel-build.cjs",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/go/medspa/:path*",
      "destination": "https://medspa-amber.vercel.app/:path*"
    },
    {
      "source": "/go/medspa",
      "destination": "https://medspa-amber.vercel.app/"
    },
    {
      "source": "/scorecard/:path*",
      "destination": "https://three-engine-scorecard.vercel.app/:path*"
    },
    {
      "source": "/scorecard",
      "destination": "https://three-engine-scorecard.vercel.app/"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
